<Window
    x:Class="VStoVSC.View.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:input="using:Avalonia.Input"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VStoVSC.ViewModels"
    x:CompileBindings="True"
    Title="{Binding VersionText, StringFormat='VStoVSC {0}'}"
    Width="500"
    Height="520"
    input:DragDrop.AllowDrop="True"
    input:DragDrop.DragLeave="DropZone_DragLeave"
    input:DragDrop.DragOver="DropZone_DragOver"
    input:DragDrop.Drop="DropZone_Drop"
    x:DataType="vm:MainWindowViewModel"
    Background="Transparent"
    CanResize="False"
    ExtendClientAreaTitleBarHeightHint="32"
    ExtendClientAreaToDecorationsHint="True"
    TransparencyLevelHint="AcrylicBlur"
    WindowStartupLocation="CenterScreen"
    Icon="avares://VStoVSC/icon/app.ico"
    mc:Ignorable="d">

    <Panel>
        <!-- ウィンドウ背景：アクリルブラー -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    MaterialOpacity="0.85"
                    TintColor="{DynamicResource Color.Window}"
                    TintOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- アクセントカラーオーバーレイ -->
        <Border
            x:Name="AccentOverlay"
            IsHitTestVisible="False"
            Opacity="0.04" />

        <!-- メインコンテンツ -->
        <Grid Margin="24,40,24,16" RowDefinitions="*,Auto">

            <!-- ━━━ D&D エリア (中央、大きく) ━━━ -->
            <!-- 通常時は ContainerAlt (バージョンカードより少し凹んだ統一感のあるダーク)。
                 ドラッグオーバー中は前面に出る DropOverlay が青フチでフィードバックを与える。 -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,16"
                Padding="20"
                Background="{DynamicResource Brush.ContainerAlt}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14"
                Cursor="Hand"
                PointerPressed="DropArea_PointerPressed"
                ToolTip.Tip="{DynamicResource Text.DropZone.Footer}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="42"
                        Text="📁" />
                    <TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.FG1}"
                        Text="{DynamicResource Text.DropZone.Message}" />
                    <TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.FG2}"
                        Text="{DynamicResource Text.DropZone.Hint}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource Brush.FG2}"
                        Opacity="0.8"
                        Text="{DynamicResource Text.DropZone.Footer}" />
                </StackPanel>
            </Border>

            <!-- ━━━ バージョン情報カード ━━━ -->
            <Border
                Grid.Row="1"
                Padding="14"
                Background="{DynamicResource Brush.Container}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.FG2}"
                        Text="{DynamicResource Text.Version.Label}" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.FG1}"
                        Text="{Binding VersionText}" />
                    <Button
                        Grid.Column="2"
                        Command="{Binding CheckForUpdateCommand}"
                        Content="{DynamicResource Text.Version.CheckUpdate}"
                        FontSize="12"
                        IsEnabled="{Binding !IsCheckingUpdate}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ━━━ ドラッグオーバーレイ (ドラッグ中のみ表示) ━━━ -->
        <Border
            x:Name="DropOverlay"
            Margin="16"
            Background="#1C1C1E"
            CornerRadius="14"
            IsHitTestVisible="False"
            IsVisible="False"
            Opacity="0.92">
            <Border
                Margin="20"
                BorderBrush="{DynamicResource Brush.DropZoneBorder}"
                BorderThickness="2"
                CornerRadius="14">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="48"
                        Text="📁" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFFFFFFF"
                        Text="{DynamicResource Text.DropZone.Message}" />
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</Window>
