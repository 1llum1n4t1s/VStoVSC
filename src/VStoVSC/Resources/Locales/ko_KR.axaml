<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.MergedDictionaries>
    <ResourceInclude Source="avares://VStoVSC/Resources/Locales/en_US.axaml"/>
  </ResourceDictionary.MergedDictionaries>

  <x:String x:Key="Text.Window.Title" xml:space="preserve">VStoVSC</x:String>
  <x:String x:Key="Text.DropZone.Message" xml:space="preserve">여기에 드래그 &amp; 드롭</x:String>
  <x:String x:Key="Text.DropZone.Hint" xml:space="preserve">또는 클릭하여 파일 선택</x:String>
  <x:String x:Key="Text.DropZone.Footer" xml:space="preserve">.sln 또는 .slnx 파일</x:String>
  <x:String x:Key="Text.Dialog.Confirm" xml:space="preserve">확인</x:String>
  <x:String x:Key="Text.Dialog.OK" xml:space="preserve">확인</x:String>
  <x:String x:Key="Text.Dialog.Cancel" xml:space="preserve">취소</x:String>
  <x:String x:Key="Text.Dialog.Yes" xml:space="preserve">예</x:String>
  <x:String x:Key="Text.Dialog.No" xml:space="preserve">아니요</x:String>
  <x:String x:Key="Text.Dialog.Error" xml:space="preserve">오류</x:String>
  <x:String x:Key="Text.Dialog.Info" xml:space="preserve">정보</x:String>
  <x:String x:Key="Text.Dialog.Warning" xml:space="preserve">경고</x:String>
  <x:String x:Key="Text.Dialog.Completed" xml:space="preserve">완료</x:String>
  <x:String x:Key="Text.Result.Success.Title" xml:space="preserve">변환 완료</x:String>
  <x:String x:Key="Text.Result.Success.Message" xml:space="preserve">{0} 변환을 성공적으로 완료했습니다</x:String>
  <x:String x:Key="Text.Result.Error.Title" xml:space="preserve">변환 오류</x:String>
  <x:String x:Key="Text.Result.Error.InvalidExtension" xml:space="preserve">.sln 또는 .slnx 파일을 선택하세요</x:String>
  <x:String x:Key="Text.Result.Error.FileNotFound" xml:space="preserve">파일을 찾을 수 없습니다: {0}</x:String>
  <x:String x:Key="Text.Result.Error.Generic" xml:space="preserve">오류가 발생했습니다: {0}</x:String>
  <x:String x:Key="Text.Version.Header" xml:space="preserve">정보</x:String>
  <x:String x:Key="Text.Version.Label" xml:space="preserve">버전</x:String>
  <x:String x:Key="Text.Version.CheckUpdate" xml:space="preserve">업데이트 확인</x:String>
  <x:String x:Key="Text.Version.Copyright" xml:space="preserve">© 2026 Yurochi</x:String>
  <x:String x:Key="Text.Version.License" xml:space="preserve">라이선스</x:String>
  <x:String x:Key="Text.Update.Latest" xml:space="preserve">최신 버전을 사용 중입니다</x:String>
  <x:String x:Key="Text.Update.Available" xml:space="preserve">새 버전을 사용할 수 있습니다</x:String>
  <x:String x:Key="Text.Update.Checking" xml:space="preserve">업데이트 확인 중...</x:String>
  <x:String x:Key="Text.Update.Downloading" xml:space="preserve">업데이트 다운로드 중...</x:String>
  <x:String x:Key="Text.Update.Downloaded" xml:space="preserve">업데이트 다운로드 완료</x:String>
  <x:String x:Key="Text.Update.Timeout" xml:space="preserve">업데이트 확인 시간 초과</x:String>
  <x:String x:Key="Text.Update.DownloadTimeout" xml:space="preserve">업데이트 다운로드 시간 초과</x:String>
  <x:String x:Key="Text.Update.CheckError" xml:space="preserve">업데이트를 확인하지 못했습니다</x:String>
  <x:String x:Key="Text.Update.Error" xml:space="preserve">업데이트 중 오류가 발생했습니다</x:String>
  <x:String x:Key="Text.Update.RepoNotConfigured" xml:space="preserve">업데이트 서버가 구성되지 않았습니다</x:String>
  <x:String x:Key="Text.Update.DevSkip" xml:space="preserve">개발 모드에서 건너뜀</x:String>
  <x:String x:Key="Text.SelfUpdate.Title" xml:space="preserve">업데이트 사용 가능</x:String>
  <x:String x:Key="Text.SelfUpdate.Available" xml:space="preserve">VStoVSC의 새 버전을 사용할 수 있습니다</x:String>
  <x:String x:Key="Text.SelfUpdate.DownloadAndInstall" xml:space="preserve">다운로드 및 설치</x:String>
  <x:String x:Key="Text.SelfUpdate.IgnoreThisVersion" xml:space="preserve">이 버전 건너뛰기</x:String>
  <x:String x:Key="Text.SelfUpdate.UpToDate" xml:space="preserve">최신 버전을 사용하고 있습니다</x:String>
  <x:String x:Key="Text.SelfUpdate.Error" xml:space="preserve">업데이트 확인 중 오류가 발생했습니다</x:String>
  <x:String x:Key="Text.SelfUpdate.Checking" xml:space="preserve">업데이트 확인 중...</x:String>
  <x:String x:Key="Text.Close" xml:space="preserve">닫기</x:String>
</ResourceDictionary>
