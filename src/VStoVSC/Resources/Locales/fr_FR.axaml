<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.MergedDictionaries>
    <ResourceInclude Source="avares://VStoVSC/Resources/Locales/en_US.axaml"/>
  </ResourceDictionary.MergedDictionaries>

  <x:String x:Key="Text.Window.Title" xml:space="preserve">VStoVSC</x:String>
  <x:String x:Key="Text.DropZone.Message" xml:space="preserve">Déposez ici</x:String>
  <x:String x:Key="Text.DropZone.Hint" xml:space="preserve">ou cliquez pour sélectionner un fichier</x:String>
  <x:String x:Key="Text.DropZone.Footer" xml:space="preserve">Fichiers .sln ou .slnx</x:String>
  <x:String x:Key="Text.Dialog.Confirm" xml:space="preserve">Confirmer</x:String>
  <x:String x:Key="Text.Dialog.OK" xml:space="preserve">OK</x:String>
  <x:String x:Key="Text.Dialog.Cancel" xml:space="preserve">Annuler</x:String>
  <x:String x:Key="Text.Dialog.Yes" xml:space="preserve">Oui</x:String>
  <x:String x:Key="Text.Dialog.No" xml:space="preserve">Non</x:String>
  <x:String x:Key="Text.Dialog.Error" xml:space="preserve">Erreur</x:String>
  <x:String x:Key="Text.Dialog.Info" xml:space="preserve">Information</x:String>
  <x:String x:Key="Text.Dialog.Warning" xml:space="preserve">Avertissement</x:String>
  <x:String x:Key="Text.Dialog.Completed" xml:space="preserve">Terminé</x:String>
  <x:String x:Key="Text.Result.Success.Title" xml:space="preserve">Conversion terminée</x:String>
  <x:String x:Key="Text.Result.Success.Message" xml:space="preserve">{0} converti avec succès</x:String>
  <x:String x:Key="Text.Result.Error.Title" xml:space="preserve">Erreur de conversion</x:String>
  <x:String x:Key="Text.Result.Error.InvalidExtension" xml:space="preserve">Veuillez sélectionner un fichier .sln ou .slnx</x:String>
  <x:String x:Key="Text.Result.Error.FileNotFound" xml:space="preserve">Fichier introuvable : {0}</x:String>
  <x:String x:Key="Text.Result.Error.Generic" xml:space="preserve">Une erreur s'est produite : {0}</x:String>
  <x:String x:Key="Text.Version.Header" xml:space="preserve">À propos</x:String>
  <x:String x:Key="Text.Version.Label" xml:space="preserve">Version</x:String>
  <x:String x:Key="Text.Version.CheckUpdate" xml:space="preserve">Vérifier les mises à jour</x:String>
  <x:String x:Key="Text.Version.Copyright" xml:space="preserve">© 2026 Yurochi</x:String>
  <x:String x:Key="Text.Version.License" xml:space="preserve">Licence</x:String>
  <x:String x:Key="Text.Update.Latest" xml:space="preserve">Vous êtes à jour</x:String>
  <x:String x:Key="Text.Update.Available" xml:space="preserve">Une nouvelle version est disponible</x:String>
  <x:String x:Key="Text.Update.Checking" xml:space="preserve">Vérification des mises à jour...</x:String>
  <x:String x:Key="Text.Update.Downloading" xml:space="preserve">Téléchargement de la mise à jour...</x:String>
  <x:String x:Key="Text.Update.Downloaded" xml:space="preserve">Mise à jour téléchargée</x:String>
  <x:String x:Key="Text.Update.Timeout" xml:space="preserve">Délai de vérification des mises à jour dépassé</x:String>
  <x:String x:Key="Text.Update.DownloadTimeout" xml:space="preserve">Délai de téléchargement dépassé</x:String>
  <x:String x:Key="Text.Update.CheckError" xml:space="preserve">Échec de la vérification des mises à jour</x:String>
  <x:String x:Key="Text.Update.Error" xml:space="preserve">Une erreur s'est produite pendant la mise à jour</x:String>
  <x:String x:Key="Text.Update.RepoNotConfigured" xml:space="preserve">Serveur de mises à jour non configuré</x:String>
  <x:String x:Key="Text.Update.DevSkip" xml:space="preserve">Ignoré en mode développement</x:String>
  <x:String x:Key="Text.SelfUpdate.Title" xml:space="preserve">Mise à jour disponible</x:String>
  <x:String x:Key="Text.SelfUpdate.Available" xml:space="preserve">Une nouvelle version de VStoVSC est disponible</x:String>
  <x:String x:Key="Text.SelfUpdate.DownloadAndInstall" xml:space="preserve">Télécharger et installer</x:String>
  <x:String x:Key="Text.SelfUpdate.IgnoreThisVersion" xml:space="preserve">Ignorer cette version</x:String>
  <x:String x:Key="Text.SelfUpdate.UpToDate" xml:space="preserve">Vous utilisez la dernière version</x:String>
  <x:String x:Key="Text.SelfUpdate.Error" xml:space="preserve">Une erreur s'est produite lors de la vérification des mises à jour</x:String>
  <x:String x:Key="Text.SelfUpdate.Checking" xml:space="preserve">Vérification des mises à jour...</x:String>
  <x:String x:Key="Text.Close" xml:space="preserve">Fermer</x:String>
</ResourceDictionary>
